# Copied to `.env` for local development. Expo inlines EXPO_PUBLIC_* at bundle time.
# Android emulator: use http://10.0.2.2:<port> to reach your machine's localhost.
# iOS simulator: http://localhost:<port> usually works.

EXPO_PUBLIC_API_GATEWAY_URL=http://10.0.2.2:8080
EXPO_PUBLIC_AUTH_SERVICE_URL=http://10.0.2.2:8080
